/* pages/dragon/dragon.wxss */

.dragon-page {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding-bottom: 140rpx;
  animation: fadeInUp 300ms ease;
}

.page-content {
  padding: 0 16px;
  animation: fadeInUp 300ms ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.date-picker {
  margin-bottom: 24rpx;
}

.date-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background-color: var(--bg-card);
  border-radius: 12rpx;
}

.date-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-family: 'JetBrains Mono', monospace;
}

.date-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
}

.section {
  margin-bottom: 24rpx;
  padding: 0 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-count {
  font-size: 24rpx;
  color: var(--text-muted);
}

.dragon-list {
  display: flex;
  flex-direction: column;
}

.dealer-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dealer-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background-color: var(--bg-card);
  border-radius: 12rpx;
  transition: all 200ms ease;
}

.dealer-item:active {
  background-color: var(--bg-card-hover);
  transform: scale(0.98);
}

.dealer-rank {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
  border-radius: 8rpx;
  font-size: 28rpx;
  color: white;
  font-weight: 600;
}

.dealer-info {
  flex: 1;
}

.dealer-name {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.dealer-stats {
  display: flex;
  gap: 24rpx;
}

.stat-buy,
.stat-sell {
  font-size: 24rpx;
  font-family: 'JetBrains Mono', monospace;
}

.stat-buy {
  color: var(--success);
}

.stat-sell {
  color: var(--danger);
}
