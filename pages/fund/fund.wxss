/* pages/fund/fund.wxss */

.fund-page {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: 16rpx 16px 120rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: var(--bg-card);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  background: transparent;
}

.search-input::placeholder {
  color: var(--text-muted);
}

.btn-search {
  font-size: 28rpx;
  padding-left: 16rpx;
}

.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.ranking-tabs {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.ranking-tab {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background-color: var(--bg-card);
  border-radius: 8rpx;
}

.ranking-tab.active {
  color: var(--text-primary);
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
}

.empty-state {
  padding: 48rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}
