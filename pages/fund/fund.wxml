<view class="fund-page">
  <!-- StatusBar -->
  <status-bar height="{{statusBarHeight}}" />

  <!-- 页面内容 -->
  <view class="page-content" style="padding-top: {{statusBarHeight}}px;">
    <!-- 搜索栏 -->
    <view class="search-bar">
      <input 
        type="text" 
        placeholder="搜索基金代码或名称" 
        class="search-input"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchFund"
        confirm-type="search"
      />
      <view class="btn-search" bindtap="onSearchFund">🔍</view>
    </view>

    <!-- 自选基金列表 -->
    <view class="section" wx:if="{{!isSearching}}">
      <view class="section-header">
        <text class="section-title">我的自选</text>
        <text class="section-count">{{watchList.length}}只</text>
      </view>
      <view class="fund-list">
        <block wx:for="{{watchList}}" wx:key="code">
          <view class="swipe-container">
            <view 
              class="swipe-content" 
              style="transform: translateX({{item.translateX || 0}}rpx);"
              bindtouchstart="onSwipeStart" 
              bindtouchmove="onSwipeMove" 
              bindtouchend="onSwipeEnd"
              data-index="{{index}}"
              data-code="{{item.code}}"
            >
              <fund-card 
                fund="{{item}}" 
                bind:tap="onFundTap"
                data-code="{{item.code}}"
              />
            </view>
            <view class="swipe-action" bindtap="onDeleteFund" data-code="{{item.code}}">
              <text class="swipe-action-text">删除</text>
            </view>
          </view>
        </block>
        <view class="empty-state" wx:if="{{watchList.length === 0}}">
          <text class="empty-text">暂无自选基金</text>
          <text class="empty-hint">在搜索结果中添加自选</text>
        </view>
      </view>
    </view>

    <!-- 搜索结果 -->
    <view class="section" wx:if="{{isSearching}}">
      <view class="section-header">
        <text class="section-title">搜索结果</text>
        <text class="section-count">{{searchResults.length}}只</text>
      </view>
      <view class="fund-list">
        <block wx:for="{{searchResults}}" wx:key="code">
          <view class="search-result-item">
            <fund-card 
              fund="{{item}}" 
              bind:tap="onFundTap"
              data-code="{{item.code}}"
            />
            <view class="btn-add {{item.isAdded ? 'added' : ''}}" bindtap="onAddToWatchlist" data-fund="{{item}}">
              <text class="btn-add-text">{{item.isAdded ? '✓ 已添加' : '+ 添加'}}</text>
            </view>
          </view>
        </block>
        <view class="empty-state" wx:if="{{searchResults.length === 0}}">
          <text class="empty-text">未找到相关基金</text>
          <text class="empty-hint">请尝试其他关键词</text>
        </view>
      </view>
    </view>

    <!-- 估值排行榜（未搜索时显示） -->
    <view class="section" wx:if="{{!isSearching}}">
      <view class="section-header">
        <text class="section-title">估值排行榜</text>
      </view>
      <view class="ranking-tabs">
        <view 
          class="ranking-tab {{rankingType === 'rise' ? 'active' : ''}}" 
          bindtap="onSwitchRanking" 
          data-type="rise"
        >
          <text class="tab-label">涨幅榜</text>
          <view class="tab-indicator" wx:if="{{rankingType === 'rise'}}"></view>
        </view>
        <view 
          class="ranking-tab {{rankingType === 'fall' ? 'active' : ''}}" 
          bindtap="onSwitchRanking" 
          data-type="fall"
        >
          <text class="tab-label">跌幅榜</text>
          <view class="tab-indicator" wx:if="{{rankingType === 'fall'}}"></view>
        </view>
      </view>
      <view class="fund-list">
        <block wx:for="{{rankingList}}" wx:key="code">
          <fund-card 
            fund="{{item}}" 
            bind:tap="onFundTap"
            data-code="{{item.code}}"
          />
        </block>
      </view>
    </view>
  </view>

  <!-- TabBar -->
  <tab-bar currentTab="{{currentTab}}" />
</view>
