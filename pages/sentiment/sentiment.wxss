/* pages/sentiment/sentiment.wxss */

.sentiment-page {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding-bottom: 140rpx;
  animation: fadeInUp 300ms ease;
}

.page-content {
  padding: 0 16px;
  animation: fadeInUp 300ms ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.emotion-section {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  padding: 0 16rpx;
  margin-bottom: 24rpx;
}

.section {
  padding: 0 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-count {
  font-size: 24rpx;
  color: var(--text-muted);
}

.etf-tabs {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
  background-color: var(--bg-card);
  border-radius: 12rpx;
  padding: 6rpx;
}

.etf-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  transition: all 200ms ease;
  position: relative;
}

.etf-tab .tab-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: color 200ms;
}

.etf-tab.active .tab-label {
  color: var(--text-primary);
  font-weight: 500;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 4rpx;
  background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
  border-radius: 2rpx;
}

.etf-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.etf-item {
  background-color: var(--bg-card);
  border-radius: 12rpx;
  padding: 24rpx;
}

.etf-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.etf-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.etf-code {
  font-size: 24rpx;
  color: var(--text-muted);
}

.etf-flow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.etf-net-inflow {
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'JetBrains Mono', monospace;
}

.etf-net-inflow.rise {
  color: var(--success);
}

.etf-net-inflow.fall {
  color: var(--danger);
}

.etf-flow-rate {
  font-size: 24rpx;
  color: var(--text-muted);
}

.etf-bar {
  height: 8rpx;
  background-color: var(--bg-secondary);
  border-radius: 4rpx;
  overflow: hidden;
}

.etf-bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 300ms ease;
}

.etf-bar-fill.rise {
  background: linear-gradient(90deg, var(--success), #34d399);
}

.etf-bar-fill.fall {
  background: linear-gradient(90deg, var(--danger), #f87171);
}
