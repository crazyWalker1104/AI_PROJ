/* components/fund-card/fund-card.wxss */

.fund-card {
  background-color: var(--bg-card);
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  transition: all 200ms ease;
  position: relative;
}

.fund-card:active {
  background-color: var(--bg-card-hover);
  transform: scale(0.98);
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.fund-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.fund-code {
  font-size: 24rpx;
  color: var(--text-muted);
  font-family: 'JetBrains Mono', monospace;
}

.fund-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  max-width: 350rpx;
}

.nav-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.estimate-nav {
  font-size: 32rpx;
  color: var(--text-primary);
  font-family: 'JetBrains Mono', monospace;
  font-weight: 600;
}

.nav-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 趋势图表 */
.trend-chart {
  height: 48rpx;
  display: flex;
  align-items: flex-end;
  padding: 0 8rpx;
  position: relative;
}

.trend-line {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 100%;
  flex: 1;
  position: relative;
  z-index: 2;
}

.trend-bar {
  width: 12rpx;
  border-radius: 6rpx;
  transition: height 300ms ease;
  min-height: 6rpx;
}

.trend-bar.rise {
  background: linear-gradient(180deg, var(--success), rgba(16, 185, 129, 0.3));
  box-shadow: 0 0 8rpx rgba(16, 185, 129, 0.3);
}

.trend-bar.fall {
  background: linear-gradient(180deg, var(--danger), rgba(239, 68, 68, 0.3));
  box-shadow: 0 0 8rpx rgba(239, 68, 68, 0.3);
}

.trend-area {
  position: absolute;
  bottom: 0;
  left: 8rpx;
  right: 8rpx;
  height: 24rpx;
  border-radius: 12rpx 12rpx 0 0;
  z-index: 1;
}

.trend-area.rise {
  background: linear-gradient(180deg, transparent, rgba(16, 185, 129, 0.08));
}

.trend-area.fall {
  background: linear-gradient(180deg, transparent, rgba(239, 68, 68, 0.08));
}

.card-footer {
  display: flex;
  justify-content: flex-end;
}

.change-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.change-badge.rise {
  background-color: rgba(16, 185, 129, 0.15);
}

.change-badge.fall {
  background-color: rgba(239, 68, 68, 0.15);
}

.change-arrow {
  font-size: 24rpx;
}

.change-value {
  font-size: 28rpx;
  font-family: 'JetBrains Mono', monospace;
  font-weight: 600;
}

.change-badge.rise .change-arrow,
.change-badge.rise .change-value {
  color: var(--success);
}

.change-badge.fall .change-arrow,
.change-badge.fall .change-value {
  color: var(--danger);
}

/* 展开提示 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.expand-hint {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 展开详情 */
.detail-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
  animation: fadeInUp 300ms ease;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.detail-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-family: 'JetBrains Mono', monospace;
}

.detail-value.rise {
  color: var(--success);
}

.detail-value.fall {
  color: var(--danger);
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
