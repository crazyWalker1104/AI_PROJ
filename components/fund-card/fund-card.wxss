/* components/fund-card/fund-card.wxss */

.fund-card {
  background-color: var(--bg-card);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.fund-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.fund-code {
  font-size: 24rpx;
  color: var(--text-muted);
  font-family: 'JetBrains Mono', monospace;
}

.fund-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  max-width: 350rpx;
}

.nav-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.estimate-nav {
  font-size: 32rpx;
  color: var(--text-primary);
  font-family: 'JetBrains Mono', monospace;
  font-weight: 600;
}

.nav-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

.card-footer {
  display: flex;
  justify-content: flex-end;
}

.change-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.change-badge.rise {
  background-color: rgba(16, 185, 129, 0.15);
}

.change-badge.fall {
  background-color: rgba(239, 68, 68, 0.15);
}

.change-arrow {
  font-size: 24rpx;
}

.change-badge.rise .change-arrow,
.change-badge.rise .change-value {
  color: var(--success);
}

.change-badge.fall .change-arrow,
.change-badge.fall .change-value {
  color: var(--danger);
}

.change-value {
  font-size: 28rpx;
  font-family: 'JetBrains Mono', monospace;
  font-weight: 600;
}
